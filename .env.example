#
# Data source:
# - local  => uses ./data/rh-planning.json
# - base44 => uses real Base44 entities through @base44/sdk
#
NODE_ENV=development
DATA_SOURCE=local

# Base44 app configuration
BASE44_APP_ID=your_app_id_here
BASE44_TOKEN=your_user_token_here
BASE44_SERVER_URL=https://base44.app

# Entity names in your Base44 app
BASE44_INTERVENANT_ENTITY=Intervenant
BASE44_INTERVENTION_ENTITY=Intervention
BASE44_POINTAGE_ENTITY=Pointage

# Optional protection for public cloud endpoint.
# If set, Base44 must send the same value as a custom header:
# x-mcp-secret: <value>
MCP_SHARED_SECRET=change_me

# Toggle MCP auth globally (default: true outside production, false in production).
# Set to false to enforce x-mcp-secret / Bearer auth checks.
DISABLE_MCP_AUTH=true

# Backward-compatible alias used by previous versions.
# DISABLE_MCP_AUTH_IN_DEV=true

# In development only (legacy switch), disable MCP auth prompt by default.
# Set to false to test auth locally.
DISABLE_MCP_AUTH_IN_DEV=true
